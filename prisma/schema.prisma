// Return Status Enum
enum ReturnStatus {
  PENDING           // Customer submitted, waiting for vendor review
  APPROVED          // Vendor approved the return
  REJECTED          // Vendor rejected the return
  RETURN_SHIPPED    // Customer shipped the item back
  RECEIVED          // Vendor received the returned item
  INSPECTING        // Vendor is inspecting the returned item
  REFUND_INITIATED  // Refund process started
  COMPLETED         // Refund completed
  CANCELLED         // Return cancelled by customer or vendor
}

