// schema.prisma
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// API BILLING
// ============================================
model ApiBill {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  service     String?
  apiName     String?
  month       Int?
  year        Int?
  period      String?
  amount      Float?
  currency    String?   @default("USD")
  usage       Json?
  status      String?   @default("pending")
  paidAt      DateTime?
  dueDate     DateTime?
  invoiceId   String?
  invoiceUrl  String?
  tags        String[]
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  // INDEXES - For billing reports and filtering
  @@index([service, year, month])  // Monthly billing by service
  @@index([status])                 // Filter pending/paid bills
  @@index([dueDate])                 // Find overdue bills
  @@index([year, month])             // Time-based aggregation
  @@index([tags])                    // Filter by tags
  @@index([createdAt])                // Audit trail
}

// ============================================
// VISITOR TRACKING
// ============================================
model Visitor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String?
  ip        String?
  page      String?
  referer   String?  @default("direct")
  userAgent String?
  country   String?  @default("Unknown")
  city      String?  @default("Unknown")
  timestamp DateTime? @default(now())
  
  // INDEXES - Analytics queries
  @@index([timestamp])                 // Time-based analytics
  @@index([sessionId])                  // User session tracking
  @@index([ip])                         // IP-based analysis
  @@index([page])                        // Page view stats
  @@index([country])                      // Geographic analytics
  @@index([referer])                       // Traffic source analysis
  @@index([timestamp, page])                 // Page views over time
  @@index([country, timestamp])               // Geo trends
  @@map("visitors")
}

// ============================================
// USER MANAGEMENT
// ============================================
model User {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  email           String           @unique
  password        String?
  firstName       String?
  lastName        String?
  avatar          String?
  phone           String?
  emailVerified   Boolean?         @default(false)
  createdAt       DateTime?        @default(now())
  updatedAt       DateTime?        @updatedAt
  role            Role?            @default(USER)

  // Relationships
  addresses       Address[]
  products        Product[]
  orders          Order[]
  reviews         Review[]
  wishlist        WishlistItem[]
  cart            CartItem[]
  payments        Payment[]
  messagesSent    Message[]        @relation("MessageSender")
  messagesReceived Message[]       @relation("MessageRecipient")
  supportTickets  SupportTicket[]
  notifications   Notification[]
  ticketResponses TicketResponse[]
  supplier        OrderItem[] @relation("SupplierOrderItems")
  rider           OrderItem[] @relation("RiderOrderItems")
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  followers       Follow[]         @relation("Follower")
  following       Follow[]         @relation("Following")
  taggedPosts     PostTaggedUser[]
  blacklistedTokens  BlacklistedToken[]
  
  // INDEXES - Critical for user lookups
  @@index([email])                     // Primary lookup field
  @@index([role])                       // Role-based queries
  @@index([createdAt])                    // New user analytics
  @@index([emailVerified])                   // Verification status
  @@index([phone])                             // Phone lookup
  @@index([role, createdAt])                     // Role-based analytics
  @@index([firstName, lastName])                    // Name search
  @@map("users")
}

// ============================================
// BLACKLISTED TOKENS
// ============================================
model BlacklistedToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime? @default(now())
  expiresAt DateTime?
  
  // INDEXES - Auth cleanup
  @@index([userId])                     // User's tokens
  @@index([expiresAt])                    // Cleanup expired tokens
  @@index([token])                          // Fast token lookup
}

// ============================================
// SOCIAL MEDIA
// ============================================
model Post {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  userId          String?         @db.ObjectId
  content         String?
  background      String?
  images          String[]
  createdAt       DateTime?       @default(now())
  updatedAt       DateTime?       @updatedAt
  privacy         PrivacySetting? @default(PUBLIC)

  // Relationships
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments        Comment[]
  likes           Like[]
  taggedUsers     PostTaggedUser[]

  // INDEXES - Social feed queries
  @@index([userId])                    // User's posts
  @@index([createdAt])                   // Chronological feed
  @@index([privacy])                       // Privacy filtering
  @@index([userId, createdAt])               // Paginated user posts
  @@index([privacy, createdAt])                // Public feed with privacy
  @@fulltext([content])                           // Search posts
  @@map("posts")
}

model PostTaggedUser {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String?  @db.ObjectId
  userId    String?  @db.ObjectId
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // INDEXES - Tag queries
  @@index([postId])                      // Tags in a post
  @@index([userId])                         // Posts where user is tagged
  @@unique([postId, userId])                   // Prevent duplicate tags
  @@map("post_tagged_users")
}

model Comment {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  postId          String?         @db.ObjectId
  userId          String?         @db.ObjectId
  content         String?
  parentId        String?         @db.ObjectId
  createdAt       DateTime?       @default(now())
  updatedAt       DateTime?       @updatedAt

  // Relationships
  post            Post?           @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          Comment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction)
  replies         Comment[]       @relation("CommentReplies")
  likes           Like[]

  // INDEXES - Comment queries
  @@index([postId])                     // Comments on a post
  @@index([userId])                        // User's comments
  @@index([parentId])                        // Threaded comments
  @@index([createdAt])                         // Chronological order
  @@index([postId, createdAt])                   // Paginated post comments
  @@index([userId, createdAt])                     // Paginated user comments
  @@map("comments")
}

model Like {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  postId          String?         @db.ObjectId
  commentId       String?         @db.ObjectId
  userId          String?         @db.ObjectId
  createdAt       DateTime?       @default(now())

  // Relationships
  post            Post?           @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         Comment?        @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // INDEXES - Like queries
  @@index([postId])                     // Post likes count
  @@index([commentId])                   // Comment likes count
  @@index([userId])                        // User's likes
  @@index([createdAt])                        // Recent likes
  @@index([postId, userId])                    // Check if user liked post
  @@index([commentId, userId])                   // Check if user liked comment
  @@unique([userId, postId, commentId])              // Prevent double likes
  @@map("likes")
}

model Follow {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  followerId      String?         @db.ObjectId
  followingId     String?         @db.ObjectId
  createdAt       DateTime?       @default(now())

  // Relationships
  follower        User?           @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following       User?           @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  // INDEXES - Follow queries
  @@index([followerId])                   // Who user follows
  @@index([followingId])                    // User's followers
  @@index([createdAt])                         // Recent follows
  @@index([followerId, followingId])               // Check follow status
  @@unique([followerId, followingId])                 // Prevent duplicate follows
  @@map("follows")
}

// ============================================
// ADDRESS MANAGEMENT
// ============================================
model Address {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  type        AddressType?
  receiver    String?
  phone       String?
  street      String?
  city        String?
  state       String?
  zipCode     String?
  country     String?
  lat         Float?
  lng         Float? 
  isDefault   Boolean? @default(false)
  createdAt   DateTime? @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  // INDEXES - Address lookups
  @@index([userId])                        // User's addresses
  @@index([userId, isDefault])                 // Default address
  @@index([city, country])                       // Geographic queries
  @@index([lat, lng])                              // Geo-spatial (if using 2dsphere)
  @@map("addresses")
}

// ============================================
// PRODUCT CATALOG
// ============================================
model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  description String?
  price       Float?
  salePrice   Float?
  sku         String   @unique
  stock       Int?     @default(0)
  images      String[]
  categoryId  String?  @db.ObjectId
  brand       String?
  weight      Float?
  dimensions  String?
  isActive    Boolean? @default(true)
  featured    Boolean? @default(false)
  tags        String[]
  attributes  Json?
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt
  supplierId  String? @default("68c8c1765038c47a4b9ef519") @db.ObjectId
  model       String? @default("https://portfolio-xi-eight-92.vercel.app/watch_test.glb")

  // Relationships
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier    User?    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]
  reviews     Review[]
  wishlist    WishlistItem[]
  cart        CartItem[]
  
  // INDEXES - CRITICAL for e-commerce scale
  @@index([categoryId])                     // Category filtering
  @@index([supplierId])                      // Vendor's products
  @@index([price])                             // Price range filtering
  @@index([brand])                               // Brand filtering
  @@index([isActive])                              // Active products only
  @@index([featured])                                // Featured products
  @@index([createdAt])                                 // New arrivals
  @@index([sku])                                          // SKU lookup (unique already)
  @@index([stock])                                          // In-stock filtering
  @@index([categoryId, isActive])                               // Active in category
  @@index([supplierId, isActive])                                 // Vendor's active products
  @@index([price, isActive])                                         // Active price range
  @@index([brand, isActive])                                           // Active brand filtering
  @@index([featured, isActive])                                          // Featured active products
  @@index([createdAt, isActive])                                            // New active arrivals
  @@index([categoryId, price, isActive])                                      // Multi-filter (category + price)
  @@fulltext([name, description, tags])                                         // Search
  @@map("products")
}

model ProductVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String?  @db.ObjectId
  name        String?
  sku         String   @unique
  color       String?
  size        String?
  price       Float?
  salePrice   Float?
  stock       Int?     @default(0)
  weight      Float?
  images      String[]
  model       String? @default("https://portfolio-xi-eight-92.vercel.app/watch_test.glb")
  isActive    Boolean? @default(true)
  options     String[]
  createdAt   DateTime? @default(now())

  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders      OrderItem[]
  
  // INDEXES - Variant queries
  @@index([productId])                     // Variants of a product
  @@index([sku])                              // SKU lookup (unique already)
  @@index([color])                              // Color filtering
  @@index([size])                                  // Size filtering
  @@index([price])                                    // Price filtering
  @@index([isActive])                                   // Active variants
  @@index([stock])                                         // Stock levels
  @@index([productId, color])                                 // Product color variants
  @@index([productId, size])                                     // Product size variants
  @@index([productId, isActive])                                    // Active product variants
  @@index([productId, price])                                          // Variants by price
  @@map("product_variants")
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  description String?
  image     String?
  parentId  String?    @db.ObjectId
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())

  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  // INDEXES - Category tree queries
  @@index([parentId])                      // Child categories
  @@index([isActive])                         // Active categories
  @@index([name])                                // Category name search
  @@index([parentId, isActive])                      // Active child categories
  @@map("categories")
}

// ============================================
// ORDER MANAGEMENT
// ============================================
model Order {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  riderId     String?
  orderNumber String   @unique
  status      OrderStatus?
  total       Float?
  subtotal    Float?
  tax         Float?   @default(0)
  shipping    Float?   @default(0)
  discount    Float?   @default(0)
  addressId   String?  @db.ObjectId
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address     Address? @relation(fields: [addressId], references: [id])
  items       OrderItem[]
  payments    Payment[]
  proofOfDelivery   ProofOfDelivery[]
  
  // INDEXES - Order queries
  @@index([userId])                         // Customer's orders
  @@index([riderId])                           // Rider's orders
  @@index([orderNumber])                          // Order lookup (unique already)
  @@index([status])                                   // Orders by status
  @@index([createdAt])                                    // Time-based queries
  @@index([addressId])                                        // Orders to address
  @@index([userId, status])                                      // Customer's orders by status
  @@index([riderId, status])                                        // Rider's orders by status
  @@index([status, createdAt])                                         // Status changes over time
  @@index([userId, createdAt])                                            // Customer's order history
  @@index([riderId, createdAt])                                              // Rider's delivery history
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String?  @db.ObjectId
  productId   String?  @db.ObjectId
  supplierId  String?  @db.ObjectId
  riderId     String?  @db.ObjectId
  trackingNumber String?
  quantity    Int?
  price       Float?
  variantInfo String?
  status      OrderStatus?
  rejectedBy String[] @default([])
  recipientName        String?
  recipientPhone       String?
  pickupAddress        String?
  pickupLatitude       Float?
  pickupLongitude      Float?
  dropoffAddress       String?
  dropoffLatitude      Float?
  dropoffLongitude     Float?
  estimatedDeliveryTime DateTime?
  eta                  String?
  actualDeliveryTime   DateTime?
  ata                  String?

  // Relationships
  supplier    User?    @relation(name:"SupplierOrderItems", fields: [supplierId], references: [id], onDelete: Cascade)
  order       Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     ProductVariant? @relation(fields: [productId], references: [id], onDelete: Cascade)
  rider       User?    @relation(name:"RiderOrderItems", fields: [riderId], references: [id], onDelete: Cascade)

  // INDEXES - CRITICAL for multi-vendor marketplace
  @@index([orderId])                          // Items in an order
  @@index([productId])                            // Product sales history
  @@index([supplierId])                              // Vendor's orders
  @@index([riderId])                                     // Rider's deliveries
  @@index([status])                                          // Item status
  @@index([trackingNumber])                                       // Tracking lookup
  @@index([supplierId, status])                                       // Vendor's orders by status
  @@index([riderId, status])                                           // Rider's deliveries by status
  @@index([orderId, supplierId])                                          // Vendor's items in order
  @@index([estimatedDeliveryTime])                                            // Delivery scheduling
  @@index([actualDeliveryTime])                                                   // Delivery completion
  @@index([pickupLatitude, pickupLongitude])                                          // Geo queries (if using 2dsphere)
  @@index([dropoffLatitude, dropoffLongitude])                                           // Geo queries (if using 2dsphere)
  @@map("order_items")
}

model ProofOfDelivery {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String   @db.ObjectId
  order         Order  @relation(fields: [orderId], references: [id])
  photoUrl      String?
  signatureData String?
  receivedBy    String
  receivedAt    DateTime @default(now())
  
  // INDEXES - Delivery proof queries
  @@index([orderId])                         // Proof for order
  @@index([receivedBy])                          // Who received
  @@index([receivedAt])                              // When delivered
}

// ============================================
// CART & WISHLIST
// ============================================
model CartItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  productId   String?  @db.ObjectId
  quantity    Int?     @default(1)
  variantInfo String?
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  // INDEXES - Cart queries
  @@index([userId])                         // User's cart
  @@index([productId])                          // Product in carts
  @@index([userId, productId])                      // Specific item in cart
  @@index([updatedAt])                                 // Abandoned carts
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  productId String?  @db.ObjectId
  createdAt DateTime? @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  // INDEXES - Wishlist queries
  @@index([userId])                         // User's wishlist
  @@index([productId])                          // Product popularity
  @@index([userId, productId])                      // Check if in wishlist
  @@index([createdAt])                                 // Recently added
  @@map("wishlist_items")
}

// ============================================
// PAYMENTS
// ============================================
model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String?       @db.ObjectId
  userId        String?       @db.ObjectId
  amount        Float?
  method        PaymentMethod?
  status        PaymentStatus?
  transactionId String?
  details       String?
  createdAt     DateTime?     @default(now())

  order         Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User?  @relation(fields: [userId], references: [id])

  // INDEXES - Payment queries
  @@index([orderId])                         // Payments for order
  @@index([userId])                              // User's payments
  @@index([status])                                  // Payment status
  @@index([transactionId])                                // Transaction lookup
  @@index([method])                                           // Payment method analytics
  @@index([createdAt])                                              // Time-based queries
  @@index([userId, status])                                             // User's payment status
  @@index([orderId, status])                                                // Order payment status
  @@map("payments")
}

// ============================================
// REVIEWS
// ============================================
model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  productId String?  @db.ObjectId
  rating    Int?
  title     String?
  comment   String?
  isApproved Boolean? @default(false)
  createdAt DateTime? @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  // INDEXES - Review queries
  @@index([userId])                         // User's reviews
  @@index([productId])                          // Product reviews
  @@index([rating])                                 // Rating filtering
  @@index([isApproved])                               // Approved reviews only
  @@index([createdAt])                                    // Recent reviews
  @@index([productId, rating])                                 // Product reviews by rating
  @@index([productId, isApproved])                                 // Approved product reviews
  @@index([productId, createdAt])                                      // Chronological product reviews
  @@map("reviews")
}

// ============================================
// MESSAGING
// ============================================
model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String?  @db.ObjectId
  recipientId String?  @db.ObjectId
  subject     String?
  body        String?
  isRead      Boolean? @default(false)
  parentId    String?  @db.ObjectId
  createdAt   DateTime? @default(now())

  sender      User?    @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User?    @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  parent      Message? @relation("MessageThread", fields: [parentId], references: [id], onDelete: NoAction)
  replies     Message[] @relation("MessageThread")

  // INDEXES - Message queries
  @@index([senderId])                         // Sent messages
  @@index([recipientId])                          // Received messages
  @@index([parentId])                                // Thread messages
  @@index([isRead])                                      // Unread messages
  @@index([createdAt])                                        // Chronological order
  @@index([recipientId, isRead])                                  // Unread for user
  @@index([senderId, recipientId])                                     // Conversation
  @@index([recipientId, createdAt])                                         // Inbox order
  @@map("messages")
}

// ============================================
// SUPPORT
// ============================================
model SupportTicket {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?        @db.ObjectId
  subject     String?
  description String?
  status      TicketStatus?  @default(OPEN)
  priority    TicketPriority? @default(MEDIUM)
  assignedTo  String?        @db.ObjectId
  createdAt   DateTime?      @default(now())
  updatedAt   DateTime?      @updatedAt

  user        User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   TicketResponse[]

  // INDEXES - Support queries
  @@index([userId])                         // User's tickets
  @@index([status])                              // Tickets by status
  @@index([priority])                                 // Tickets by priority
  @@index([assignedTo])                                   // Assigned agent
  @@index([createdAt])                                          // Time-based queries
  @@index([status, priority])                                         // Queue filtering
  @@index([assignedTo, status])                                           // Agent's tickets
  @@index([userId, status])                                                   // User's tickets by status
  @@map("support_tickets")
}

model TicketResponse {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  ticketId  String?       @db.ObjectId
  userId    String?       @db.ObjectId
  message   String?
  isInternal Boolean?     @default(false)
  createdAt DateTime?     @default(now())

  ticket    SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id])

  // INDEXES - Response queries
  @@index([ticketId])                      // Responses for ticket
  @@index([userId])                            // User's responses
  @@index([isInternal])                            // Internal vs public
  @@index([createdAt])                                 // Chronological order
  @@index([ticketId, createdAt])                             // Ticket conversation order
  @@map("ticket_responses")
}

// ============================================
// NOTIFICATIONS
// ============================================
model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?          @db.ObjectId
  type      NotificationType?
  title     String?
  message   String?
  isRead    Boolean?         @default(false)
  link      String?
  createdAt DateTime?        @default(now())

  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // INDEXES - Notification queries
  @@index([userId])                         // User's notifications
  @@index([isRead])                              // Read/unread
  @@index([type])                                    // Notification type
  @@index([createdAt])                                    // Time-based
  @@index([userId, isRead])                                  // Unread for user
  @@index([userId, createdAt])                                      // User's notification history
  @@index([userId, type])                                              // User's notifications by type
  @@map("notifications")
}

// ============================================
// VEHICLE TYPES (for logistics)
// ============================================
model VehicleType {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  maxCapacityKg Float?
  maxVolumeM3   Float?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  icon          String?
  cost          Float?
  perKmRate     Float?
  rushTimeAdd   Float?
  
  // INDEXES
  @@index([name])                          // Vehicle type lookup
  @@index([perKmRate])                          // Pricing queries
}

// ============================================
// COUNTERS (for order/tracking numbers)
// ============================================
model OrderCounter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime @unique
  counter   Int @default(0)
  
  // INDEXES
  @@index([date])                           // Daily counter lookup
}

model TrackingCounter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime @unique
  counter   Int @default(0)
  
  // INDEXES
  @@index([date])                           // Daily counter lookup
}

// ============================================
// ENUMS (unchanged)
// ============================================
enum Role {
  ADMINISTRATOR
  MANAGER
  RIDER
  USER
}

enum AddressType {
  HOME
  WORK
  BILLING
  SHIPPING
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  PAYPAL
  STRIPE
  BANK_TRANSFER
  COD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  ORDER_UPDATE
  PAYMENT_CONFIRMATION
  SHIPMENT
  PROMOTIONAL
  SUPPORT
  SOCIAL
}

enum PrivacySetting {
  PUBLIC
  FRIENDS
  ONLY_ME
}
